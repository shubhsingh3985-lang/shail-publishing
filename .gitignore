# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Next.js ─────────────────────────────────────────────────────────────────
.next/
out/
build/

# ─── Environment variables ───────────────────────────────────────────────────
# Never commit real credentials
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Keep the example file so others know what vars are needed
!.env.local.example

# ─── Firebase ────────────────────────────────────────────────────────────────
.firebase/
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
ui-debug.log
.firebaserc

# ─── Service account keys ────────────────────────────────────────────────────
# These grant full admin access — never commit them
service-account*.json
*-service-account.json
serviceAccountKey.json

# ─── OS files ────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Editor / IDE ────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.history/

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Testing ─────────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Misc ────────────────────────────────────────────────────────────────────
.cache/
.temp/
.tmp/
*.tgz

